<%= form_with(model: chat, url: object_chats_path(object_druid: druid)) do |form| %>
  <%= render SdrViewComponents::Forms::TextAreaComponent.new(form: form, field_name: :prompt, label: "Prompt", label_hidden: true, rows: 5, autofocus: true) %>
  <%= render SdrViewComponents::Forms::SubmitComponent.new(form: form, label: "Start new chat", classes: 'mt-3') %>
<% end %>
