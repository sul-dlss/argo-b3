<div id="<%= dom_id chat %>" class="w-full sm:w-auto my-5 space-y-3">
  <div>
    <strong class="block font-medium mb-1">Model:</strong>
    <%= chat.model&.label || default_model_display_name %>
  </div>

  <div>
    <strong class="block font-medium mb-1">Messages:</strong>
    <%= chat.messages.count %>
  </div>

  <div>
    <strong class="block font-medium mb-1">Created:</strong>
    <%= chat.created_at.strftime("%B %d, %Y at %I:%M %p") %>
  </div>
</div>
