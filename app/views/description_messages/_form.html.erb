<%= form_with(model: message, url: object_description_chat_messages_path(object_druid: druid, description_chat_id: message.chat.id), id: "new_message") do |form| %>
  <%= render SdrViewComponents::Forms::TextAreaComponent.new(form: form, field_name: :content, label: "Message", label_hidden: true, rows: 5, autofocus: true) %>
  <%= render SdrViewComponents::Forms::SubmitComponent.new(label: "Submit", classes: 'mt-3') %>
<% end %>
