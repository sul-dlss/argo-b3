<%= form_with model: @bulk_action_form, url: bulk_actions_manage_rights_path do |form| %>
  <%= render BulkActions::FormComponent.new(bulk_action_config: @bulk_action_config, form:, with_close_version: true) do |component| %>

    <fieldset class="mb-3">
      <%= render SdrViewComponents::Forms::RadioButtonComponent.new(form:, field_name: :rights,
                                                                    label_text: 'World',
                                                                    input_value: 'world') do |component| %>
        <%= component.with_additional_container_content do %>
          <%= form.hidden_field :view, value: 'world' %>
          <%= form.hidden_field :download, value: 'world' %>
        <% end %>
                                                                    <% end %>
      <%= render SdrViewComponents::Forms::RadioButtonComponent.new(form:, field_name: :rights,
                                                                    label_text: 'Dark',
                                                                    input_value: 'dark') do |component| %>
        <%= component.with_additional_container_content do %>
          <%= form.hidden_field :view, value: 'dark' %>
          <%= form.hidden_field :download, value: 'none' %>
        <% end %>
      <% end %>
    </fieldset>

    <%= render BulkActions::SelectSourceComponent.new(form:, search_form: @last_search_form, total_results: @total_results) %>
  <% end %>
<% end %>
